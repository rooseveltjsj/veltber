---
// About Section - Diferenciais
---

<section id="sobre" class="relative py-24 bg-dark-900 overflow-hidden">
	<!-- Background Elements -->
	<div class="absolute inset-0 opacity-5">
		<div class="absolute top-1/3 right-1/4 w-96 h-96 bg-accent-500 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10 container mx-auto px-6">
		<!-- Header -->
		<div class="max-w-3xl mx-auto text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
				Nosso <span class="bg-gradient-to-r from-primary-500 to-accent-500 bg-clip-text text-transparent">Diferencial</span>
			</h2>
			<p class="text-xl md:text-2xl text-slate-300 leading-relaxed">
				Acreditamos que uma casa inteligente deve ser 
				<span class="text-accent-500 font-semibold">privada</span> e 
				<span class="text-primary-500 font-semibold">eterna</span>.
			</p>
		</div>

		<!-- Pillars Grid -->
		<div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
			<!-- Pilar 1: Privacidade -->
			<div class="group relative bg-dark-800/50 backdrop-blur-sm border border-accent-500/20 rounded-2xl p-8 hover:border-accent-500/50 transition-all duration-300 hover:shadow-accent hover:-translate-y-2">
				<!-- Icon -->
				<div class="w-16 h-16 bg-accent-500/10 border border-accent-500/30 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-all duration-300">
					<svg class="w-8 h-8 text-accent-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
					</svg>
				</div>

				<!-- Title -->
				<h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-500 transition-colors">
					Privacidade
				</h3>

				<!-- Description -->
				<p class="text-slate-400 mb-4 leading-relaxed">
					Seus dados permanecem <span class="text-accent-500 font-semibold">100% locais</span>. 
					Arquitetura <span class="font-medium">Local-first</span> que garante controle total sem dependência de nuvens externas.
				</p>

				<!-- Badge -->
				<div class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent-500/10 border border-accent-500/30 rounded-full text-xs text-accent-500 font-medium">
					<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
					</svg>
					Local-First
				</div>
			</div>

			<!-- Pilar 2: Independência -->
			<div class="group relative bg-dark-800/50 backdrop-blur-sm border border-primary-500/20 rounded-2xl p-8 hover:border-primary-500/50 transition-all duration-300 hover:shadow-premium hover:-translate-y-2">
				<!-- Icon -->
				<div class="w-16 h-16 bg-primary-500/10 border border-primary-500/30 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-500/20 transition-all duration-300">
					<svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
						<circle cx="9" cy="7" r="4"></circle>
						<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
						<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
					</svg>
				</div>

				<!-- Title -->
				<h3 class="text-2xl font-bold text-white mb-4 group-hover:text-primary-500 transition-colors">
					Independência
				</h3>

				<!-- Description -->
				<p class="text-slate-400 mb-4 leading-relaxed">
					Integração <span class="text-primary-500 font-semibold">agnóstica</span> de múltiplas marcas. 
					Sem amarras ou ecossistemas fechados.
				</p>
			<!-- Alexa Integration Highlight -->
			<div class="mb-4 p-3 bg-gradient-to-r from-sky-500/10 to-primary-500/10 border border-sky-500/30 rounded-lg">
				<p class="text-sm text-slate-300 leading-relaxed">
					<span class="text-sky-400 font-semibold">🎤 Alexa + Home Assistant:</span> Unificamos o controle de voz da Alexa com a inteligência local do Home Assistant. Use dispositivos que já possui ou compre no 
					<span class="text-primary-400 font-medium">Mercado Livre</span> e 
					<span class="text-primary-400 font-medium">Shopee</span>.
				</p>
			</div>
				<!-- Brand Logos -->
				<div class="flex flex-wrap gap-2 mb-4">
					<span class="px-3 py-1 bg-dark-900/70 border border-dark-700 rounded-lg text-xs text-slate-400 font-medium">
						Xiaomi
					</span>
					<span class="px-3 py-1 bg-dark-900/70 border border-dark-700 rounded-lg text-xs text-slate-400 font-medium">
						Sonoff
					</span>
					<span class="px-3 py-1 bg-dark-900/70 border border-dark-700 rounded-lg text-xs text-slate-400 font-medium">
						Philips
					</span>
					<span class="px-3 py-1 bg-dark-900/70 border border-dark-700 rounded-lg text-xs text-slate-400 font-medium">
						Samsung
					</span>
					<span class="px-3 py-1 bg-dark-900/70 border border-dark-700 rounded-lg text-xs text-slate-400 font-medium">
						+100 marcas
					</span>
				</div>

				<!-- Badge -->
				<div class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary-500/10 border border-primary-500/30 rounded-full text-xs text-primary-500 font-medium">
					<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
					</svg>
					Multi-Marca
				</div>
			</div>

			<!-- Pilar 3: Segurança Avançada -->
			<div class="group relative bg-dark-800/50 backdrop-blur-sm border border-accent-500/20 rounded-2xl p-8 hover:border-accent-500/50 transition-all duration-300 hover:shadow-accent hover:-translate-y-2">
				<!-- Icon -->
				<div class="w-16 h-16 bg-accent-500/10 border border-accent-500/30 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-all duration-300">
					<svg class="w-8 h-8 text-accent-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
						<path d="M9 12l2 2 4-4"></path>
					</svg>
				</div>

				<!-- Title -->
				<h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-500 transition-colors">
					Segurança Avançada
				</h3>

				<!-- Description -->
				<p class="text-slate-400 mb-4 leading-relaxed">
					<span class="text-accent-500 font-semibold">IA de próxima geração</span> que distingue humanos de animais. 
					Alertas inteligentes sem falsos positivos.
				</p>

				<!-- Feature List -->
				<div class="space-y-2 mb-4">
					<div class="flex items-center gap-2 text-sm text-slate-400">
						<svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
						</svg>
						<span>Detecção de pessoas</span>
					</div>
					<div class="flex items-center gap-2 text-sm text-slate-400">
						<svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
						</svg>
						<span>Diferenciação de pets</span>
					</div>
					<div class="flex items-center gap-2 text-sm text-slate-400">
						<svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
						</svg>
						<span>Zero falsos alarmes</span>
					</div>
				</div>

				<!-- Badge -->
				<div class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent-500/10 border border-accent-500/30 rounded-full text-xs text-accent-500 font-medium">
					<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
					</svg>
					IA Avançada
				</div>
			</div>
		</div>

		<!-- Hardware Showcase -->
		<div class="mt-20 max-w-6xl mx-auto">
			<div class="text-center mb-12">
				<h3 class="text-3xl font-bold text-white mb-4">
					Infraestrutura <span class="bg-gradient-to-r from-primary-500 to-accent-500 bg-clip-text text-transparent">Profissional</span>
				</h3>
				<p class="text-slate-400">Hardware enterprise em rack organizado e documentado</p>
			</div>

			<!-- Hardware Image -->
		<div class="mb-8 relative group overflow-hidden rounded-3xl">
			<!-- Dark Overlay -->
			<div class="absolute inset-0 bg-slate-950/40 group-hover:bg-slate-950/20 transition-colors duration-300 z-10"></div>
			<!-- Emerald Glow on Hover -->
			<div class="absolute inset-0 bg-gradient-to-tr from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10"></div>
			<!-- Image -->
			<img 
				src={`${import.meta.env.BASE_URL}images/hardware-raspberry.jpg`}
				alt="Hardware Profissional - Raspberry Pi e Servidores para Automação Residencial" 
				class="w-full h-64 md:h-96 object-cover transition-transform duration-500 group-hover:scale-105 filter contrast-125 saturate-75"
				loading="lazy"
				width="1200"
				height="800"
			/>
		</div>

			<div class="grid md:grid-cols-2 gap-8">
				<!-- Hardware Image 1: Rack Profissional -->
				<div class="group relative">
					<div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-slate-700/50 rounded-3xl shadow-xl overflow-hidden p-8 hover:border-primary-500/50 transition-all duration-500 hover:shadow-premium-lg">
						<!-- Mock Rack Content -->
						<div class="space-y-6">
							<div class="flex items-center justify-between mb-6">
								<h4 class="text-white font-semibold text-lg">Rack de Automação Residencial</h4>
								<div class="flex gap-2">
									<div class="w-2 h-2 bg-accent-500 rounded-full animate-pulse"></div>
									<span class="text-xs text-slate-400">Online</span>
								</div>
							</div>

							<!-- Rack Slots -->
							<div class="space-y-3">
								<!-- Server Home Assistant -->
								<div class="bg-dark-900/80 border border-primary-500/30 rounded-xl p-4 hover:border-primary-500/60 transition-all">
									<div class="flex items-center gap-4">
										<div class="w-12 h-12 bg-primary-500/20 rounded-lg flex items-center justify-center">
											<svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
											</svg>
										</div>
										<div class="flex-1">
											<p class="text-white font-medium">Home Assistant Server</p>
											<p class="text-xs text-slate-400">Intel NUC - 16GB RAM</p>
										</div>
										<div class="flex gap-1">
											<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
											<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
											<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
											<div class="w-2 h-2 bg-slate-700 rounded-full"></div>
										</div>
									</div>
								</div>

								<!-- Switch de Rede -->
								<div class="bg-dark-900/80 border border-slate-700/50 rounded-xl p-4 hover:border-accent-500/60 transition-all">
									<div class="flex items-center gap-4">
										<div class="w-12 h-12 bg-accent-500/20 rounded-lg flex items-center justify-center">
											<svg class="w-6 h-6 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
											</svg>
										</div>
										<div class="flex-1">
											<p class="text-white font-medium">Switch PoE Gerenciável</p>
											<p class="text-xs text-slate-400">24 Portas Gigabit</p>
										</div>
										<div class="flex gap-1">
											<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
											<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
										</div>
									</div>
								</div>

								<!-- Backup UPS -->
								<div class="bg-dark-900/80 border border-slate-700/50 rounded-xl p-4 hover:border-yellow-500/60 transition-all">
									<div class="flex items-center gap-4">
										<div class="w-12 h-12 bg-yellow-500/20 rounded-lg flex items-center justify-center">
											<svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
											</svg>
										</div>
										<div class="flex-1">
											<p class="text-white font-medium">UPS - No-break</p>
											<p class="text-xs text-slate-400">1500VA - Bateria 100%</p>
										</div>
										<div class="flex gap-1">
											<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
										</div>
									</div>
								</div>
							</div>

							<!-- Footer Description -->
							<div class="pt-4 border-t border-slate-700/50">
								<p class="text-xs text-slate-400 text-center">
									<span class="text-primary-500 font-semibold">Hardware de automação em rack profissional</span> - Organizado, documentado e escalável
								</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Hardware Image 2: Integração Multi-Protocolo -->
				<div class="group relative">
					<div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-slate-700/50 rounded-3xl shadow-xl overflow-hidden p-8 hover:border-accent-500/50 transition-all duration-500 hover:shadow-accent">
						<div class="space-y-6">
							<div class="flex items-center justify-between mb-6">
								<h4 class="text-white font-semibold text-lg">Protocolos Integrados</h4>
								<span class="px-3 py-1 bg-accent-500/20 border border-accent-500/30 rounded-full text-xs text-accent-500 font-medium">
									Agnóstico
								</span>
							</div>

							<!-- Protocol Cards -->
							<div class="grid grid-cols-2 gap-3">
								<!-- Zigbee -->
								<div class="bg-dark-900/80 border border-slate-700/50 rounded-xl p-4 text-center hover:border-primary-500/50 transition-all">
									<div class="w-10 h-10 bg-primary-500/20 rounded-lg flex items-center justify-center mx-auto mb-2">
										<svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"></path>
										</svg>
									</div>
									<p class="text-white text-sm font-medium">Zigbee</p>
									<p class="text-xs text-slate-400">2.4 GHz</p>
								</div>

								<!-- Z-Wave -->
								<div class="bg-dark-900/80 border border-slate-700/50 rounded-xl p-4 text-center hover:border-accent-500/50 transition-all">
									<div class="w-10 h-10 bg-accent-500/20 rounded-lg flex items-center justify-center mx-auto mb-2">
										<svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
										</svg>
									</div>
									<p class="text-white text-sm font-medium">Z-Wave</p>
									<p class="text-xs text-slate-400">868 MHz</p>
								</div>

								<!-- Wi-Fi -->
								<div class="bg-dark-900/80 border border-slate-700/50 rounded-xl p-4 text-center hover:border-primary-500/50 transition-all">
									<div class="w-10 h-10 bg-primary-500/20 rounded-lg flex items-center justify-center mx-auto mb-2">
										<svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0"></path>
										</svg>
									</div>
									<p class="text-white text-sm font-medium">Wi-Fi</p>
									<p class="text-xs text-slate-400">2.4/5 GHz</p>
								</div>

								<!-- Bluetooth -->
								<div class="bg-dark-900/80 border border-slate-700/50 rounded-xl p-4 text-center hover:border-accent-500/50 transition-all">
									<div class="w-10 h-10 bg-accent-500/20 rounded-lg flex items-center justify-center mx-auto mb-2">
										<svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1.5a3.5 3.5 0 110 7H9m0-7v7m0-7h1.5a3.5 3.5 0 010 7H9"></path>
										</svg>
									</div>
									<p class="text-white text-sm font-medium">Bluetooth</p>
									<p class="text-xs text-slate-400">BLE 5.0</p>
								</div>
							</div>

							<!-- Integration List -->
							<div class="bg-dark-900/60 rounded-xl p-4 space-y-2">
								<p class="text-white text-sm font-medium mb-3">Marcas Integradas:</p>
								<div class="flex flex-wrap gap-2">
									<span class="px-2 py-1 bg-dark-800 border border-slate-700 rounded text-xs text-slate-300">Xiaomi</span>
									<span class="px-2 py-1 bg-dark-800 border border-slate-700 rounded text-xs text-slate-300">Sonoff</span>
									<span class="px-2 py-1 bg-dark-800 border border-slate-700 rounded text-xs text-slate-300">Philips Hue</span>
									<span class="px-2 py-1 bg-dark-800 border border-slate-700 rounded text-xs text-slate-300">Samsung</span>
									<span class="px-2 py-1 bg-dark-800 border border-slate-700 rounded text-xs text-slate-300">Tuya</span>
									<span class="px-2 py-1 bg-dark-800 border border-slate-700 rounded text-xs text-slate-300">Shelly</span>
									<span class="px-2 py-1 bg-accent-500/20 border border-accent-500 rounded text-xs text-accent-500 font-medium">+100 mais</span>
								</div>
							</div>

							<!-- Footer Description -->
							<div class="pt-4 border-t border-slate-700/50">
								<p class="text-xs text-slate-400 text-center">
									Infraestrutura multi-protocolo para <span class="text-accent-500 font-semibold">máxima compatibilidade</span>
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
