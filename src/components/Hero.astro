---
// Hero Component - Página Principal
---

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden">
	<!-- Background Image -->
	<div class="absolute inset-0">
		<img 
			src={`${import.meta.env.BASE_URL}images/hero-background.jpg`}
			alt="Casa Inteligente Moderna" 
			class="w-full h-full object-cover"
		/>
		<!-- Dark Overlay 65% -->
		<div class="absolute inset-0 bg-black/65"></div>
	</div>

	<!-- Gradient Accents -->
	<div class="absolute inset-0 opacity-10">
		<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-500 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-500 rounded-full blur-3xl"></div>
	</div>

	<!-- Grid Pattern Overlay -->
	<div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-5"></div>

	<!-- Content -->
	<div class="relative z-10 container mx-auto px-6 py-20">
		<div class="max-w-5xl mx-auto text-center">
			<!-- Icons Section -->
			<div class="flex justify-center items-center gap-6 mb-8 animate-fade-in">
				<!-- Home Icon -->
				<div class="w-16 h-16 bg-primary-500/10 border border-primary-500/30 rounded-2xl backdrop-blur-sm flex items-center justify-center transform hover:scale-110 transition-transform duration-300">
					<svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
					</svg>
				</div>

				<!-- Connection Lines -->
				<div class="flex-1 h-px bg-gradient-to-r from-primary-500/50 via-accent-500/50 to-primary-500/50 max-w-24"></div>

				<!-- Network Icon -->
				<div class="w-16 h-16 bg-accent-500/10 border border-accent-500/30 rounded-2xl backdrop-blur-sm flex items-center justify-center transform hover:scale-110 transition-transform duration-300">
					<svg class="w-8 h-8 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
					</svg>
				</div>

				<!-- Connection Lines -->
				<div class="flex-1 h-px bg-gradient-to-r from-primary-500/50 via-accent-500/50 to-primary-500/50 max-w-24"></div>

				<!-- Shield Icon (Local Security) -->
				<div class="w-16 h-16 bg-accent-500/10 border border-accent-500/30 rounded-2xl backdrop-blur-sm flex items-center justify-center transform hover:scale-110 transition-transform duration-300">
					<svg class="w-8 h-8 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
					</svg>
				</div>
			</div>

			<!-- Headline -->
			<h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
				<span class="text-white">Sua Casa Inteligente,</span>
				<br />
				<span class="bg-gradient-to-r from-primary-500 via-accent-500 to-primary-500 bg-clip-text text-transparent">
					Sem Fronteiras
				</span>
				<br />
				<span class="text-white">e Sem Reféns de Marcas</span>
			</h1>

			<!-- Sub-headline -->
			<p class="text-xl md:text-2xl text-slate-300 mb-12 max-w-4xl mx-auto leading-relaxed">
				Especialistas em integração agnóstica via <span class="text-accent-500 font-semibold">Home Assistant</span>. 
				<br class="hidden md:block" />
				Segurança de dados <span class="text-primary-500 font-semibold">local</span>, escalabilidade real e controle total na palma da sua mão.
			</p>

			<!-- Feature Pills -->
			<div class="flex flex-wrap justify-center gap-3 mb-12">
				<span class="px-4 py-2 bg-dark-800/50 border border-primary-500/30 rounded-full text-sm text-slate-300 backdrop-blur-sm">
					🔒 100% Local
				</span>
				<span class="px-4 py-2 bg-dark-800/50 border border-accent-500/30 rounded-full text-sm text-slate-300 backdrop-blur-sm">
					🔌 Multi-Marca
				</span>
				<span class="px-4 py-2 bg-dark-800/50 border border-primary-500/30 rounded-full text-sm text-slate-300 backdrop-blur-sm">
					📱 Controle Remoto
				</span>
				<span class="px-4 py-2 bg-dark-800/50 border border-accent-500/30 rounded-full text-sm text-slate-300 backdrop-blur-sm">
					⚡ Automações Inteligentes
				</span>
			</div>

			<!-- CTA Button -->
			<div class="flex justify-center">
				<a 
					href="#contato" 
					class="group relative inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-accent-500 to-primary-500 rounded-xl font-semibold text-lg text-white shadow-premium-lg hover:shadow-premium transition-all duration-300 transform hover:scale-105 hover:-translate-y-1"
				>
					<span>Quero um Projeto Personalizado</span>
					<svg class="w-6 h-6 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</a>
			</div>

			<!-- Trust Indicators -->
			<div class="mt-16 flex flex-wrap justify-center items-center gap-8 text-sm text-slate-400">
				<div class="flex items-center gap-2">
					<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
					</svg>
					<span>Suporte Técnico Especializado</span>
				</div>
				<div class="flex items-center gap-2">
					<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
					</svg>
					<span>Instalação Profissional</span>
				</div>
				<div class="flex items-center gap-2">
					<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
					</svg>
					<span>Garantia de Qualidade</span>
				</div>
			</div>

			<!-- Dashboard Preview -->
			<div class="mt-20">
				<div class="relative group">
					<!-- Image Placeholder -->
					<div class="relative bg-gradient-to-br from-dark-800 to-dark-900 border border-primary-500/30 rounded-3xl shadow-xl overflow-hidden p-8 hover:border-primary-500/50 transition-all duration-500 hover:shadow-premium-lg">
						<!-- Mock Dashboard Content -->
						<div class="space-y-4">
							<!-- Header Bar -->
							<div class="flex items-center justify-between pb-4 border-b border-slate-700/50">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-accent-500 rounded-lg flex items-center justify-center">
										<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
										</svg>
									</div>
									<div>
										<h3 class="text-white font-semibold text-lg">Home Assistant Dashboard</h3>
										<p class="text-slate-400 text-xs">Interface limpa e intuitiva</p>
									</div>
								</div>
								<div class="flex gap-2">
									<div class="w-3 h-3 bg-red-500 rounded-full"></div>
									<div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
									<div class="w-3 h-3 bg-accent-500 rounded-full"></div>
								</div>
							</div>

							<!-- Dashboard Cards Grid -->
							<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
								<!-- Card 1: Iluminação -->
								<div class="bg-dark-900/80 backdrop-blur-sm border border-slate-700/50 rounded-xl p-4 hover:border-primary-500/50 transition-all">
									<div class="flex items-center gap-2 mb-2">
										<svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
										</svg>
										<span class="text-slate-300 text-sm font-medium">Sala de Estar</span>
									</div>
									<div class="flex items-center justify-between">
										<span class="text-white font-semibold">85%</span>
										<div class="w-10 h-5 bg-accent-500 rounded-full relative">
											<div class="absolute right-1 top-0.5 w-4 h-4 bg-white rounded-full shadow"></div>
										</div>
									</div>
								</div>

								<!-- Card 2: Temperatura -->
								<div class="bg-dark-900/80 backdrop-blur-sm border border-slate-700/50 rounded-xl p-4 hover:border-primary-500/50 transition-all">
									<div class="flex items-center gap-2 mb-2">
										<svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
										</svg>
										<span class="text-slate-300 text-sm font-medium">Clima</span>
									</div>
									<div class="flex items-center justify-between">
										<span class="text-white font-semibold">22°C</span>
										<span class="text-accent-500 text-xs">Confortável</span>
									</div>
								</div>

								<!-- Card 3: Segurança -->
								<div class="bg-dark-900/80 backdrop-blur-sm border border-slate-700/50 rounded-xl p-4 hover:border-primary-500/50 transition-all">
									<div class="flex items-center gap-2 mb-2">
										<svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
										</svg>
										<span class="text-slate-300 text-sm font-medium">Segurança</span>
									</div>
									<div class="flex items-center justify-between">
										<span class="text-white font-semibold">Armado</span>
										<div class="w-2 h-2 bg-accent-500 rounded-full animate-pulse"></div>
									</div>
								</div>

								<!-- Card 4: Energia -->
								<div class="bg-dark-900/80 backdrop-blur-sm border border-slate-700/50 rounded-xl p-4 hover:border-primary-500/50 transition-all">
									<div class="flex items-center gap-2 mb-2">
										<svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
										</svg>
										<span class="text-slate-300 text-sm font-medium">Consumo</span>
									</div>
									<div class="flex items-center justify-between">
										<span class="text-white font-semibold">2.4 kW</span>
										<span class="text-accent-500 text-xs">-15%</span>
									</div>
								</div>
							</div>

							<!-- Status Bar -->
							<div class="flex items-center justify-between pt-2 text-xs text-slate-400">
								<div class="flex items-center gap-4">
									<span class="flex items-center gap-1">
										<div class="w-2 h-2 bg-accent-500 rounded-full"></div>
										12 dispositivos online
									</span>
									<span>Última atualização: agora</span>
								</div>
								<span class="text-primary-500 font-medium">Interface limpa do Dashboard do Home Assistant</span>
							</div>
						</div>

						<!-- Glow Effect -->
						<div class="absolute inset-0 bg-gradient-to-t from-primary-500/0 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
					</div>

					<!-- Floating Badge -->
					<div class="absolute -top-4 -right-4 bg-gradient-to-r from-accent-500 to-primary-500 text-white px-4 py-2 rounded-full text-xs font-bold shadow-xl">
						✨ Software de Alto Nível
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
		</svg>
	</div>
</section>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(-20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 1s ease-out;
	}
</style>
