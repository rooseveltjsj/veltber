<section id="solucoes" class="relative py-32 bg-gradient-to-b from-dark-950 via-dark-900 to-dark-950 overflow-hidden">
	<!-- Background Elements Animados -->
	<div class="absolute inset-0 opacity-5">
		<div class="absolute top-1/4 left-1/3 w-96 h-96 bg-primary-500 rounded-full blur-3xl animate-pulse" style="animation-duration: 4s;"></div>
		<div class="absolute bottom-1/4 right-1/3 w-96 h-96 bg-accent-500 rounded-full blur-3xl animate-pulse" style="animation-duration: 6s; animation-delay: 1s;"></div>
