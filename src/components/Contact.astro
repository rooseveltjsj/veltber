---
// Contact Section & Footer
---

<section id="contato" class="relative py-32 overflow-hidden" style="background-color: #0a0e17;">
	<!-- Background Elements -->
	<div class="absolute inset-0 opacity-5">
		<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500 rounded-full blur-3xl animate-pulse" style="animation-duration: 4s;"></div>
		<div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-500 rounded-full blur-3xl animate-pulse" style="animation-duration: 6s; animation-delay: 1s;"></div>
	</div>

	<div class="relative z-10 container mx-auto px-6">
		<!-- Header -->
		<div class="max-w-4xl mx-auto text-center mb-20">
			<div class="inline-flex items-center gap-2 px-5 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-cyan-400 text-sm font-semibold mb-8 backdrop-blur-sm">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
				</svg>
				Fale Conosco
			</div>
			<h2 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-tight">
				Inicie Sua <span class="bg-gradient-to-r from-cyan-400 via-blue-400 to-sky-400 bg-clip-text text-transparent">Transformação</span>
			</h2>
			<p class="text-xl text-slate-300 leading-relaxed">
				Especialistas em automação empresarial e residencial de alto nível. Receba consultoria técnica personalizada.
			</p>
		</div>

		<!-- Two Column Layout -->
		<div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-start">
			
			<!-- Coluna Esquerda: Imagem + Bullet Points -->
			<div class="space-y-8">
				<!-- Imagem com Glow Ciano -->
				<div class="relative group">
