					<div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-3xl blur-xl opacity-30 group-hover:opacity-50 transition-opacity duration-500"></div>
					
					<!-- Image Container -->
					<div class="relative overflow-hidden rounded-3xl border-2 border-cyan-500/30 group-hover:border-cyan-500/60 transition-all duration-500">
						<img 
							src={`${import.meta.env.BASE_URL}images/contato-veltber.webp`}
							alt="Consultoria Técnica Veltber - Automação Residencial Premium" 
							class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
							loading="lazy"
							width="800"
							height="600"
						/>
						<!-- Overlay Gradient -->
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>
					</div>
				</div>

				<!-- Bullet Points com Ícones -->
				<div class="space-y-5">
					<!-- Automação Agnóstica -->
					<div class="flex items-start gap-4 p-4 bg-slate-900/40 backdrop-blur-sm border border-cyan-500/20 rounded-2xl hover:border-cyan-500/50 transition-all duration-300 group">
						<div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border border-cyan-500/40 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
