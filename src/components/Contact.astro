								<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1 group-hover:text-cyan-400 transition-colors">Automação Agnóstica</h3>
							<p class="text-slate-400 text-sm leading-relaxed">Integramos qualquer marca: Alexa, Google Home, Tuya, Sonoff e mais.</p>
						</div>
					</div>

					<!-- Segurança de Dados Local -->
					<div class="flex items-start gap-4 p-4 bg-slate-900/40 backdrop-blur-sm border border-cyan-500/20 rounded-2xl hover:border-cyan-500/50 transition-all duration-300 group">
